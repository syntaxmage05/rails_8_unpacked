<header class="border-b border-white/10 bg-slate-900/95 backdrop-blur">
  <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <div class="flex lg:flex-1">
      <%= link_to tasks_path, class: "-m-1.5 flex items-center gap-3 p-1.5" do %>
        <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-indigo-500 text-sm font-black tracking-wide text-white">RU</span>
        <span class="text-sm font-semibold text-white">Rails 8 Unpacked</span>
      <% end %>
    </div>

    <div class="hidden lg:flex lg:gap-x-12">
      <%= link_to "Tasks", tasks_path, class: "text-sm font-semibold text-white/90 transition hover:text-white" %>
    </div>

    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <%= link_to "New task", new_task_path, class: "rounded-full bg-indigo-500 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:bg-indigo-400" %>
    </div>
  </nav>
</header>
