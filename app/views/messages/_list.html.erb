<div id="messages_list" class="space-y-4" role="log" aria-live="polite" aria-relevant="additions text">
  <% if messages.any? %>
    <%= render messages %>
  <% else %>
    <div class="rounded-2xl border border-dashed border-white/10 bg-slate-950/40 px-6 py-10 text-center">
      <p class="text-sm font-medium text-slate-300">No messages yet</p>
      <p class="mt-2 text-sm text-slate-500">Start the conversation for this task by sending the first message.</p>
    </div>
  <% end %>
</div>
