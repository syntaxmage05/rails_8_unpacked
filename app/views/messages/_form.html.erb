<div id="new_message">
  <% if message.errors.any? %>
    <div class="mb-4 rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200 shadow-sm" role="alert" aria-live="assertive">
      <h3 class="text-sm font-semibold"><%= pluralize(message.errors.count, "error") %> prevented this message from being sent:</h3>
      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm">
        <% message.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [task, message], class: "space-y-4" do |form| %>
    <div>
      <%= form.label :content, "Add a message", class: "mb-2 block text-sm font-semibold text-slate-200" %>
      <%= form.text_area :content,
          rows: 4,
          autofocus: true,
          placeholder: "Type your message here...",
          class: "block w-full rounded-2xl border border-white/10 bg-slate-950/80 px-4 py-3 text-white shadow-sm transition placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-4 focus:ring-indigo-500/10" %>
    </div>

    <div class="flex justify-end">
      <%= form.submit "Send message", class: "inline-flex cursor-pointer items-center justify-center rounded-full bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:-translate-y-0.5 hover:bg-indigo-400" %>
    </div>
  <% end %>
</div>
