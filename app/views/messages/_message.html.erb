<article id="<%= dom_id message %>" class="rounded-2xl border border-white/10 bg-slate-950/70 p-4 shadow-lg shadow-black/20">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-white"><%= message.user.email_address %></p>
      <p class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-500">Message</p>
    </div>

    <time
      class="text-xs font-medium text-slate-400"
      datetime="<%= message.created_at.iso8601 %>"
      title="<%= message.created_at.strftime('%b %d, %Y %I:%M %p') %>"
      data-controller="relative-time"
      data-relative-time-timestamp-value="<%= message.created_at.iso8601 %>">
      <%= time_ago_in_words(message.created_at) %> ago
    </time>
  </div>

  <p class="mt-4 whitespace-pre-wrap text-sm leading-7 text-slate-300"><%= message.content %></p>
</article>
