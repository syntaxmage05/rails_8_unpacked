<% content_for :title, "Showing task" %>

<div class="mx-auto w-full max-w-4xl space-y-8">
  <% if notice.present? %>
    <p id="notice" class="rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-200 shadow-sm">
      <%= notice %>
    </p>
  <% end %>

  <section class="rounded-[2rem] border border-white/10 bg-slate-900/80 px-6 py-8 shadow-2xl shadow-black/20 backdrop-blur-xl sm:px-8 sm:py-10">
    <div class="space-y-5">
      <% if @task.status.present? %>
        <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-slate-200">
          <%= @task.human_enum_value(:status) %>
        </span>
      <% end %>

      <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-indigo-300">Task overview</p>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl"><%= @task.name.presence || "Untitled task" %></h1>
        <p class="max-w-2xl text-sm leading-7 text-slate-400 sm:text-base">
          Review the task details, message collaborators, and keep the discussion attached to the work.
        </p>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] border border-white/10 bg-slate-900/80 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
    <%= render @task %>
  </section>

  <section class="rounded-[2rem] border border-white/10 bg-slate-900/80 p-6 shadow-2xl shadow-black/20 backdrop-blur-xl sm:p-8">
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-white">Messages</h2>
          <p class="mt-2 text-sm leading-7 text-slate-400">See who said what and when, directly from this task.</p>
        </div>
        <%= render "messages/count", count: @messages.size %>
      </div>

      <%= render "messages/notice", notice: nil %>
      <%= render "messages/form", task: @task, message: @message %>
      <%= render "messages/list", messages: @messages %>
    </div>
  </section>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
    <%= link_to "Edit task", edit_task_path(@task), class: "inline-flex items-center justify-center rounded-full bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:-translate-y-0.5 hover:bg-indigo-400" %>
    <%= link_to "Back to tasks", tasks_path, class: "inline-flex items-center justify-center rounded-full border border-white/10 bg-slate-900 px-5 py-3 text-sm font-semibold text-slate-200 shadow-sm transition hover:border-white/20 hover:bg-slate-800" %>
    <%= button_to "Delete task", @task, method: :delete, form_class: "sm:inline-block", class: "inline-flex w-full cursor-pointer items-center justify-center rounded-full bg-rose-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-rose-500/20 transition hover:-translate-y-0.5 hover:bg-rose-500 sm:w-auto", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
