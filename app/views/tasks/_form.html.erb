<% base_input_classes = "block w-full rounded-2xl border bg-slate-900/80 px-4 py-3 text-white shadow-sm transition placeholder:text-slate-500 focus:outline-none focus:ring-4" %>
<% valid_input_classes = "border-white/10 focus:border-indigo-500 focus:ring-indigo-500/10" %>
<% invalid_input_classes = "border-rose-400/60 text-rose-100 focus:border-rose-500 focus:ring-rose-500/10" %>

<%= form_with(model: task, class: "space-y-6") do |form| %>
  <% if task.errors.any? %>
    <div id="error_explanation" class="rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-rose-200 shadow-sm">
      <h2 class="text-sm font-semibold">
        <%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:
      </h2>

      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm">
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="overflow-hidden rounded-3xl border border-white/10 bg-slate-900/80 shadow-2xl shadow-black/20 backdrop-blur-xl">
    <div class="border-b border-white/10 px-6 py-5 sm:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-indigo-300">Task details</p>
      <p class="mt-2 text-sm text-slate-400">Add the core information for this task and choose its current status.</p>
    </div>

    <div class="space-y-6 px-6 py-6 sm:px-8 sm:py-8">
      <div>
        <%= form.label :name, class: "mb-2 block text-sm font-semibold text-slate-200" %>
        <%= form.text_field :name,
            placeholder: "e.g. Prepare onboarding checklist",
            class: "#{base_input_classes} #{task.errors[:name].any? ? invalid_input_classes : valid_input_classes}" %>
      </div>

      <div>
        <%= form.label :description, class: "mb-2 block text-sm font-semibold text-slate-200" %>
        <%= form.textarea :description,
            rows: 6,
            placeholder: "Write a short description so the team understands the goal and scope.",
            class: "#{base_input_classes} #{task.errors[:description].any? ? invalid_input_classes : valid_input_classes}" %>
      </div>

      <div>
        <%= form.label :status, class: "mb-2 block text-sm font-semibold text-slate-200" %>
        <%= form.select :status,
            Task.human_enum_options(:status),
            {},
            class: "#{base_input_classes} #{task.errors[:status].any? ? invalid_input_classes : valid_input_classes}" %>
      </div>
    </div>
  </section>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
    <%= link_to(task.persisted? ? "Cancel" : "Back to tasks", task.persisted? ? task_path(task) : tasks_path, class: "inline-flex items-center justify-center rounded-full border border-white/10 bg-slate-900 px-5 py-3 text-sm font-semibold text-slate-200 shadow-sm transition hover:border-white/20 hover:bg-slate-800") %>
    <%= form.submit(task.persisted? ? "Update task" : "Create task", class: "inline-flex cursor-pointer items-center justify-center rounded-full bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:-translate-y-0.5 hover:bg-indigo-400" ) %>
  </div>
<% end %>
